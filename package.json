{
  "name": "truthseek",
  "displayName": "TruthSeek Eval Harness",
  "description": "Run TruthSeek evals from the editor: one-click runs, a live gate badge in the status bar, pass/fail case tree, and a scorecard panel with the separability plane.",
  "version": "0.2.0",
  "publisher": "UnifyDynamics",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Testing", "Machine Learning", "Visualization"],
  "keywords": ["eval", "llm", "ai safety", "benchmark", "truthseek"],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlmrx/truthseek-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/mlmrx/truthseek-vscode/issues"
  },
  "homepage": "https://github.com/mlmrx/truthseek-vscode#readme",
  "main": "./extension.js",
  "activationEvents": ["workspaceContains:**/harness/cli.py", "workspaceContains:**/out/scorecard.json"],
  "contributes": {
    "commands": [
      { "command": "truthseek.runMock", "title": "TruthSeek: Run eval (mock, offline)" },
      { "command": "truthseek.runConfig", "title": "TruthSeek: Run eval (config.yaml)" },
      { "command": "truthseek.runCategory", "title": "TruthSeek: Run one category…" },
      { "command": "truthseek.runStrict", "title": "TruthSeek: Run strict gate (CI check)" },
      { "command": "truthseek.selectTarget", "title": "TruthSeek: Configure target model…" },
      { "command": "truthseek.openScorecard", "title": "TruthSeek: Open scorecard panel" },
      { "command": "truthseek.newCase", "title": "TruthSeek: New eval case file" },
      { "command": "truthseek.refresh", "title": "TruthSeek: Refresh", "icon": "$(refresh)" }
    ],
    "configuration": {
      "title": "TruthSeek",
      "properties": {
        "truthseek.harnessPath": {
          "type": "string", "default": "",
          "description": "Path to the TruthSeek harness repo. Leave empty to use the workspace root."
        },
        "truthseek.pythonBin": {
          "type": "string", "default": "python3",
          "description": "Python executable used to run the harness."
        },
        "truthseek.casesPath": {
          "type": "string", "default": "cases/",
          "description": "Cases directory, relative to the harness repo."
        },
        "truthseek.configPath": {
          "type": "string", "default": "config.yaml",
          "description": "Harness config file, relative to the harness repo."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        { "id": "truthseek", "title": "TruthSeek", "icon": "$(shield)" }
      ]
    },
    "views": {
      "truthseek": [
        { "id": "truthseekRuns", "name": "Scorecard", "icon": "$(shield)" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "truthseek.refresh", "when": "view == truthseekRuns", "group": "navigation" },
        { "command": "truthseek.runMock", "when": "view == truthseekRuns", "group": "navigation" },
        { "command": "truthseek.selectTarget", "when": "view == truthseekRuns", "group": "navigation" }
      ]
    },
    "snippets": [
      { "language": "yaml", "path": "./snippets/truthseek.code-snippets" }
    ]
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
